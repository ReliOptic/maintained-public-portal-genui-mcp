{
  "name": "portal-genui-mcp",
  "version": "0.1.0",
  "description": "Maintained public portal GenUI MCP stdio server",
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist/",
    "catalog/compiled.sqlite",
    "claude-extension.json",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "compile": "node --loader ts-node/esm scripts/compile-catalog.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "better-sqlite3": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": false
}
